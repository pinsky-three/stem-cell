PORT=4200
DATABASE_URL=postgresql://user:password@localhost:5432/stem_cell

# ── Auth ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:4200
SESSION_TTL_HOURS=168

# Comma-separated GitHub logins that are auto-promoted to role='admin' on
# OAuth callback. Required to access /admin/*. Matched case-insensitively.
# Default bootstraps the project owner; add more users here as needed.
ADMIN_GITHUB_USERNAMES=<your-github-username>

# ── SMTP (optional — email features disabled if SMTP_HOST is empty) ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ── OAuth2: GitHub (optional) ───────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth2: Google (optional) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenCode (AI code generation) ──────────────────────────────────────
OPENCODE_PORT_BASE=14000
OPENCODE_IDLE_TIMEOUT_SECS=600
OPENCODE_SERVER_PASSWORD=
OPENCODE_WORKDIR_BASE=/tmp/stem-cell-projects

# AI provider — set ONE of these API keys. The process manager auto-
# generates OpenCode's inline config (OPENCODE_CONFIG_CONTENT) from
# whichever key is present. No manual JSON config needed.
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Ollama (local models, privacy-first) ───────────────────────────────
# Uses OpenCode's OpenAI-compatible provider against a local Ollama server.
# Set OLLAMA_MODELS (comma-separated tags) to enable. No API key required.
# Pull models first:  ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODELS=gemma4

# Model to use (provider-prefixed). Examples:
#   openrouter/anthropic/claude-sonnet-4
#   openrouter/google/gemini-2.5-pro
#   anthropic/claude-sonnet-4
#   ollama/llama3.2                ← local Ollama model
OPENCODE_MODEL=openrouter/deepseek/deepseek-v3.2

# Advanced: override the auto-generated config with raw JSON.
# See https://opencode.ai/docs/config for the full schema.
# OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","provider":{"openrouter":{"options":{"apiKey":"{env:OPENROUTER_API_KEY}"}}},"model":"openrouter/anthropic/claude-sonnet-4"}

# ── Spawn / preview (optional) ───────────────────────────────────────────
# Spawn mode: "subprocess" (default) or "container".
SPAWN_MODE=subprocess

# Subprocess spawn retries `mise run dev` with an OpenCode repair pass between tries (1–10).
# STEM_CELL_DEV_START_ATTEMPTS=3
# OpenCode SSE wait per build job (seconds, 60–86400). Default 1800 (30 min).
# STEM_CELL_RUN_BUILD_SSE_TIMEOUT_SECS=1800
# Replace the default OpenCode system prompt (host-owned preview; no dev servers). Whitespace-only disables it.
# STEM_CELL_OPENCODE_SYSTEM_PROMPT=

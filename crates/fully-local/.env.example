# ── fully-local OpenAI-compatible server ────────────────────────────────
# Copy to `.env` (in the directory you run the binary from) or export the
# vars manually. Everything here has a sane default.

# Path to the GGUF weights. Resolved relative to the process CWD.
# When launched via `cargo run -p fully-local`, CWD is `crates/fully-local/`,
# so the default `../../models/Bonsai-8B.gguf` lands at the workspace root.
# For installed binaries, use an absolute path.
OXIBONSAI_MODEL_PATH=../../models/Bonsai-8B.gguf

# Optional. Path to a HuggingFace tokenizer.json file. Without it,
# /v1/chat/completions returns raw token IDs as text (useful for plumbing
# smoke tests, useless for real chat).
# OXIBONSAI_TOKENIZER_PATH=models/tokenizer.json

# host:port to bind. Default loopback; set 0.0.0.0:8080 for LAN.
OXIBONSAI_BIND_ADDR=127.0.0.1:8080

# Context window. Must be <= what the model was trained for (Bonsai: 65536).
OXIBONSAI_MAX_SEQ_LEN=4096

# Sampling preset: greedy | balanced | creative | precise | conversational
OXIBONSAI_PRESET=balanced

# RNG seed for reproducibility (used across all requests on this engine).
OXIBONSAI_SEED=42

# Log level filter: error | warn | info | debug | trace, or per-target
# e.g. "info,oxibonsai_runtime=debug".
OXIBONSAI_LOG_LEVEL=info

# Emit JSON-formatted log lines (good for container/log-aggregator deploys).
OXIBONSAI_JSON_LOGS=false

      <a href="/admin/github_installations" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">GithubInstallation</h3>

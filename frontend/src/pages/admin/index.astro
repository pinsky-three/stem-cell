    });
    fetch('/api/github_installations').then(r=>r.json()).then(d=>{
      document.getElementById('count-github_installations').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-github_installations').textContent='--';
    });
    fetch('/api/repo_connections').then(r=>r.json()).then(d=>{
      document.getElementById('count-repo_connections').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-repo_connections').textContent='--';
    });
  </script>
</Base>

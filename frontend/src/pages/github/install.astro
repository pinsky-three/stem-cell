---
import Base from "../../layouts/Base.astro";
import InstallGithubAppButton from "../../components/InstallGithubAppButton";

// This page is intentionally static-renderable. The install button is a
// React island that calls /github/app/info at runtime to decide whether to
// render itself, so we can ship one build regardless of whether the App is
// wired in a given environment.
//
// The Setup URL handler at /github/app/setup redirects here after a
// successful install with ?github=installed&installation=<uuid>. We read
// those markers on the client and swap the CTA for a success card.
---
<Base title="Connect GitHub" noindex={true}>
  <main class="mx-auto flex min-h-[calc(100vh-4rem)] max-w-2xl flex-col items-center justify-center px-6 py-16">
    <div id="status-banner" class="hidden mb-8 w-full"></div>

    <div class="w-full rounded-2xl border border-neutral-800 bg-neutral-900/40 p-10 text-center">
      <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-600/10 text-indigo-400">
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" class="h-7 w-7">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold tracking-tight">Connect your GitHub account</h1>
      <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-neutral-400">
        Install the Stem Cell GitHub App so each new project template gets persisted
        as a real repo in your account, with scoped access via a short-lived installation
        token — no long-lived PATs required.
      </p>

      <div class="mt-8 flex justify-center">
        <InstallGithubAppButton client:only="react" />
      </div>

      <p class="mt-6 text-xs text-neutral-500">
        Installation is revocable at any time from GitHub → Settings → Applications.
      </p>
    </div>

    <!-- What happens next -->
    <section class="mt-12 w-full">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-neutral-500">
        What the install grants
      </h2>
      <ul class="mt-5 space-y-3 text-sm text-neutral-300">
        <li class="flex items-start gap-3">
          <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-green-500/10 text-green-400">
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
          </span>
          <span>Create new repos from our project templates directly in your GitHub account.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-green-500/10 text-green-400">
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
          </span>
          <span>Push experiment branches and open pull requests without handling any repo tokens yourself.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-green-500/10 text-green-400">
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
          </span>
          <span>Revocable access — remove the app from GitHub and Stem Cell immediately loses its grip.</span>
        </li>
      </ul>
    </section>
  </main>

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const status = params.get("github");
      if (!status) return;

      const banner = document.getElementById("status-banner");
      if (!banner) return;

      const installation = params.get("installation");

      /**
       * Map the ?github= markers the Setup URL handler emits onto a
       * human-readable banner. Keeping this mapping client-side (not in the
       * URL) means we can iterate on copy without touching the backend.
       */
      const variants = {
        installed: {
          tone: "success",
          title: "GitHub App installed",
          body: installation
            ? `Connected (installation ${installation.slice(0, 8)}…). You can now connect a repo to any project.`
            : "You can now connect a repo to any project.",
        },
        not_configured: {
          tone: "warn",
          title: "GitHub App not configured on this server",
          body: "The install completed on GitHub, but the server is missing App credentials so the installation was not mirrored locally. Ask an admin to wire GITHUB_APP_ID / private key / webhook secret.",
        },
      };

      const v = variants[status];
      if (!v) return;

      const styles = v.tone === "success"
        ? "border-green-800 bg-green-950/30 text-green-300"
        : "border-amber-800 bg-amber-950/30 text-amber-300";

      banner.className = `mb-8 w-full rounded-lg border px-4 py-3 ${styles}`;
      banner.innerHTML = `
        <p class="text-sm font-semibold">${v.title}</p>
        <p class="mt-1 text-xs opacity-90">${v.body}</p>
      `;
      banner.classList.remove("hidden");

      // Strip the markers from the address bar so a back-forward-reload
      // doesn't re-show the banner. History replace keeps the scroll pos.
      const clean = new URL(window.location.href);
      clean.searchParams.delete("github");
      clean.searchParams.delete("installation");
      window.history.replaceState(null, "", clean.toString());
    })();
  </script>
</Base>

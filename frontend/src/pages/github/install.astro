---
import Base from "../../layouts/Base.astro";
import InstallGithubAppButton from "../../components/InstallGithubAppButton";
---
<Base title="GitHub Storage" noindex={true}>
  <main class="relative min-h-[calc(100vh-4rem)] overflow-hidden bg-[#060709] px-6 py-16 text-zinc-100">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute left-1/2 top-0 h-px w-[80vw] -translate-x-1/2 bg-linear-to-r from-transparent via-emerald-300/40 to-transparent"></div>
      <div class="absolute -left-32 top-20 h-72 w-72 rounded-full bg-emerald-500/10 blur-3xl"></div>
      <div class="absolute -right-32 bottom-20 h-80 w-80 rounded-full bg-sky-500/10 blur-3xl"></div>
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"></div>
    </div>

    <div class="relative mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <section class="space-y-8">
        <div id="status-banner" class="hidden"></div>

        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-300/20 bg-emerald-300/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-emerald-200">
          Storage handshake
        </div>

        <div>
          <h1 class="max-w-3xl text-5xl font-semibold tracking-[-0.06em] text-zinc-50 sm:text-6xl">
            Keep every Stem Cell project alive in GitHub.
          </h1>
          <p class="mt-6 max-w-xl text-base leading-8 text-zinc-400">
            Sign in with GitHub for identity, then let the GitHub App handle
            repository access. If the App is already installed, Stem Cell syncs
            it directly instead of sending you back into GitHub settings.
          </p>
        </div>

        <div class="grid gap-3 text-sm text-zinc-300 sm:grid-cols-3">
          <div class="rounded-3xl border border-zinc-800 bg-zinc-950/60 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">One</p>
            <p class="mt-2 font-medium">OAuth identifies you</p>
          </div>
          <div class="rounded-3xl border border-zinc-800 bg-zinc-950/60 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">Two</p>
            <p class="mt-2 font-medium">App grants repo scope</p>
          </div>
          <div class="rounded-3xl border border-zinc-800 bg-zinc-950/60 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">Three</p>
            <p class="mt-2 font-medium">Builds persist as PRs</p>
          </div>
        </div>
      </section>

      <section>
        <InstallGithubAppButton client:only="react" />
      </section>
    </div>

    <section class="relative mx-auto mt-16 grid max-w-6xl gap-4 md:grid-cols-3">
      <article class="rounded-[1.75rem] border border-zinc-800 bg-zinc-950/50 p-6">
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-200">
          No PATs
        </h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400">
          Repo operations use short-lived installation tokens minted by the App.
          OAuth never owns repo writes.
        </p>
      </article>
      <article class="rounded-[1.75rem] border border-zinc-800 bg-zinc-950/50 p-6">
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-200">
          Existing installs
        </h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400">
          The sync button reconciles your already-installed personal App
          installation without depending on GitHub's post-install redirect.
        </p>
      </article>
      <article class="rounded-[1.75rem] border border-zinc-800 bg-zinc-950/50 p-6">
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-200">
          Unique repo
        </h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400">
          Each project gets one active repo connection. Successful edits push a
          branch and open a pull request against that repo.
        </p>
      </article>
    </section>
  </main>

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const status = params.get("github");
      if (!status) return;

      const banner = document.getElementById("status-banner");
      if (!banner) return;

      const installation = params.get("installation");
      const variants = {
        installed: {
          tone: "success",
          title: "GitHub App connected",
          body: installation
            ? `Synced installation ${installation.slice(0, 8)}. New successful builds will persist to GitHub.`
            : "New successful builds will persist to GitHub.",
        },
        not_configured: {
          tone: "warn",
          title: "GitHub App credentials missing",
          body: "GitHub completed its side, but this deploy is missing App credentials. Add the env vars and sync again.",
        },
      };

      const v = variants[status];
      if (!v) return;

      const styles = v.tone === "success"
        ? "border-emerald-300/20 bg-emerald-300/10 text-emerald-100"
        : "border-amber-300/20 bg-amber-300/10 text-amber-100";

      banner.className = `rounded-3xl border px-5 py-4 ${styles}`;
      banner.innerHTML = `
        <p class="text-sm font-semibold">${v.title}</p>
        <p class="mt-1 text-sm opacity-80">${v.body}</p>
      `;
      banner.classList.remove("hidden");

      const clean = new URL(window.location.href);
      clean.searchParams.delete("github");
      clean.searchParams.delete("installation");
      window.history.replaceState(null, "", clean.toString());
    })();
  </script>
</Base>

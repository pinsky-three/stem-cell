---
import Base from "../layouts/Base.astro";
---

<Base title="Stem Cell — Pinsky Studio">
  <div class="flex min-h-screen flex-col items-center justify-center px-6">
    <div class="max-w-xl text-center">
      <h1 class="text-4xl font-semibold tracking-tight text-neutral-600 sm:text-5xl">
        Stem Cell
      </h1>
      <p class="mt-4 text-lg text-neutral-400">
        Infrastructure layer for intelligent services.
      </p>
      <div class="mt-10 flex items-center justify-center gap-6 text-sm text-neutral-300">
        <span>&copy; {new Date().getFullYear()} Pinsky Studio</span>
        <a href="mailto:bregy@minsky.cc" class="underline underline-offset-4 transition hover:text-neutral-500">
          Contact
        </a>
      </div>
    </div>
  </div>
</Base>
